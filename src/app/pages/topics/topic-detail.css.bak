.main-container {
  min-height: 84vh;
  width: 95%;
  padding: 5px;
}

.answer-bubble {
  position: relative;
  margin-top: 24px;
  padding: 16px 20px;
  border-radius: 12px;
  background-color: #f5f5f5;
  border: 1px solid #ddd;
  box-shadow: 0 4px 12px rgba(167, 137, 137, 0.08);
}

.close-btn {
  position: absolute;
  top: 8px;
  right: 12px;
  border: none;
  background: none;
  font-size: 20px;
  cursor: pointer;
}

.loading {
  font-style: italic;
  color: #666;
}

.subtle {
  margin-top: 6px;
  font-size: 0.9rem;
  opacity: 0.8;
}

.description {
  font-style: italic;
}

.boldText {
  font-weight: bold;
}

.text-red{
  color: red; 
}

.redTextItal {
  color: red;
  font-size: 14px;
  font-style:italic;
}

.click-here-btn {
  background: #1a3a6b;
  color: #fff;
  border: none;
  padding: 9px 18px;
  font-size: 13px;
  font-weight: 600;
  border-radius: 8px;
  cursor: pointer;
  transition: background 0.18s ease, transform 0.1s ease;
  white-space: nowrap;
}

.click-here-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 14px rgba(0,0,0,0.2);
}

.click-here-btn:active {
  transform: translateY(0);
  box-shadow: 0 3px 8px rgba(0,0,0,0.15);
}

.solutions {
  padding-left: 1.25rem;
}

.solution-item {
  margin-bottom: 1rem;
}

.solution-text {
  margin-bottom: 0.25rem;
  white-space: pre-line;
}

.solution-body {
  display: block;
  margin-left: 0ch;   /* approx 4 spaces */
}

.solution-body-politician {
  display: block;
  margin-left: 2ch;   /* approx 4 spaces */
}

.solution-voting {
  flex-shrink: 0;            /* keep widget compact */
  display: flex;
  align-items: center;
}

.solutions-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 600;
  color: #1a3a6b;
  text-decoration: none;
  border: 1.5px solid #1a3a6b;
  padding: 7px 16px;
  border-radius: 8px;
  transition: all 0.18s ease;
  margin-bottom: 4px;
}

.solution-footer {
  display: flex;
  align-items: center;       /* vertical alignment */
  justify-content: space-between;
  gap: 1rem;
  margin-top: 0.5rem;
}


.solution-stats {
  display: flex;
  align-items: flex-end;
  gap: 1rem;
}

/* Left summary block */
.stats-summary {
  display: flex;
  gap: 1rem;
  align-items: center;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat .label {
  font-size: 0.75rem;
  color: #888;
}

.stat .value {
  font-weight: 600;
}

/* Distribution chart */
.distribution {
  display: flex;
  align-items: flex-end;
  gap: 6px;
  height: 80px;
}

.distribution-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.distribution-title {
  font-size: 12px;
  font-weight: 600;
  margin-bottom: 6px;
  color: #555;
}

.distribution-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 16px;
}

/* Bar frame */
.bar-container {
  height: 60px;
  width: 100%;
  background-color: #eee;
  border-radius: 3px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

/* Actual bar */
.bar-fill {
  width: 100%;
  height: 0%;
  background-color: #4caf50;
  transition: height 0.3s ease;
}

/* X-axis labels (1–10) */
.distribution-label {
  font-size: 10px;
  margin-top: 4px;
}

.vote-container {
  width: fit-content;
}

.vote-label-row {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  margin-top: 4px;
}

.questions {
  overflow-x: hidden;
}

.question-text{
  color:#b07a2a;
  font-size: 18px;
}

.question-number {
  display: inline-block;
  background: #1a3a6b;
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.06em;
  padding: 3px 10px;
  border-radius: 20px;
  margin-bottom: 10px;
}

.question-title {
  font-size: 20px;
  font-weight: 700;
  color: #1a1a2e;
  margin: 0 0 16px;
}

/* Right side rail */
.question-actions {
  background: #f8f9fb;
  border-radius: 12px;
  border: 1px solid #e5e7eb;
  padding: 18px 20px;
  margin-top: 20px;
  display: flex;
  gap: 20px;
  align-items: flex-start;
}

.actions-left {
  display: flex;
  flex-direction: column;
  gap: 6px;
  min-width: 130px;
  flex-shrink: 0;
}

/* RIGHT COLUMN */
.actions-right {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  padding: 0;
  background: transparent;
  border-radius: 0;
  box-shadow: none;
}

.question-actions a,
.question-actions button {
  text-align: left;
}

.actions-title {
  font-size: 13px;
  font-weight: 600;
  color: #1a1a2e;
}

.actions-note {
  font-size: 12px;
  color: #6b7280;
  line-height: 1.4;
}

/* AI Pills */
.ai-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 7px 13px;
  background: #fff;
  border: 1.5px solid #e5e7eb;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 500;
  color: #374151;
  text-decoration: none;
  transition: all 0.18s ease;
  white-space: nowrap;
}

.ai-pill:hover {
  border-color: #1a3a6b;
  color: #1a3a6b;
  background: #eef1f9;
  transform: translateY(-1px);
}

/* Color dots inside pills — add a span.ai-dot inside each pill */
.ai-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
  flex-shrink: 0;
}

.ai-dot--chatgpt    { background: #10a37f; }
.ai-dot--perplexity { background: #6366f1; }
.ai-dot--gemini     { background: #e8a325; }
.ai-dot--grok       { background: #e03d3d; }
.ai-dot--metaai     { background: #0866ff; }
.ai-dot--copilot    { background: #0078d4; }

@media (max-width: 768px) {  
  .question-actions {
    grid-template-columns: 1fr;   /* single column */
    padding: 16px;
  }

  /* Stack everything vertically */
  .actions-left,
  .actions-right {
    grid-column: 1;
  }

  /* Put links ABOVE copy section */
  .actions-right {
    order: 1;
    padding: 12px;
  }

  .actions-left {
    order: 2;
    margin-top: 12px;
  }

  /* Make copy button full width */
  .click-here-btn {
    width: 100%;
    text-align: center;
  }

  .actions-note {
    text-align: center;
  }  
  .solutions {
    padding-left: 0px;
  }

  .solution-footer {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .solution-voting,
  .solution-stats {
    width: 100%;
  }

  .distribution {
    display: flex;
    overflow-x: auto;
    gap: 8px;
  }

  .distribution-bar {
    min-width: 20px;
    flex-shrink: 0;
  }

  .solution-text {
    overflow-wrap: break-word;
  }
}