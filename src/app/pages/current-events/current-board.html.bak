<h2 class="section-title">The Big Board</h2>

<div class="main-container">

  <!-- Question block -->
  <div class="question-block">
    <span class="boldText">We asked Claude:</span>
    <p class="question-text" style="margin-top: 8px;">{{shareLink1}}</p>

    <div class="question-actions">
      <div class="actions-left">
        <span class="actions-title">Ask Other AI Sites</span>
        <span class="actions-note">Copy, then paste into a site:</span>
        <button (click)="copyToClipboard(shareLink1, 1)" class="click-here-btn">
          Copy Question
          @if (linkCopied[1]) { <span class="text-red">Copied!</span> }
        </button>
      </div>

      <div class="actions-right">
        <a href="https://chat.openai.com/" target="_blank" class="ai-pill">
          <span class="ai-dot ai-dot--chatgpt"></span>ChatGPT
        </a>
        <a href="https://www.perplexity.ai/" target="_blank" class="ai-pill">
          <span class="ai-dot ai-dot--perplexity"></span>Perplexity
        </a>
        <a href="https://gemini.google.com/app" target="_blank" class="ai-pill">
          <span class="ai-dot ai-dot--gemini"></span>Gemini
        </a>
        <a href="https://grok.com/" target="_blank" class="ai-pill">
          <span class="ai-dot ai-dot--grok"></span>Grok
        </a>
        <a href="https://www.meta.ai/" target="_blank" class="ai-pill">
          <span class="ai-dot ai-dot--metaai"></span>Meta AI
        </a>
        <a href="https://copilot.microsoft.com/" target="_blank" class="ai-pill">
          <span class="ai-dot ai-dot--copilot"></span>Copilot
        </a>
      </div>
    </div>
  </div>

  <!-- Claude's reply -->
  <div class="question-block">
    <span class="boldText">Claude replied with the following:</span>

    @for (topics of topics11to20; track topics; let i = $index) {
      <div style="margin-top: 20px;">
        <span class="question-number">{{ i + 1 < 10 ? '0' + (i + 1) : i + 1 }}</span>
        <h3 class="question-title">{{ topics11to20[i].title }}</h3>

        <div>{{topics11to20[i].description}}</div>

        <hr class="question-divider">
        <a class="solutions-link"
          [routerLink]="['/topic', topics11to20[i].id]"
          [queryParams]="{ from: 'current-board' }">
          See Solutions &rarr;
        </a>
      </div>
    }
  </div>

</div>
