.main-container {
  padding: 5px;
}

.description {
  font-style: italic;
}

.boldText {
  font-weight: bold;
}

.redTextItal {
  color: red;
  font-size: 14px;
  font-style:italic;
}

.section-title {
  text-align: center;
}

.text-red{
  color: red; 
}

.question-block {
  display: flex;
  flex-direction: column;   /* ⭐ stack vertically */
  gap: 16px;
  margin-bottom: 24px;
}

.question-text{
  color:#C08331; 
  font-size: 18px;
}

ol {
  margin-top: 12px;
  padding-left: 20px;
}

li {
  margin-bottom: 0px;
}

.question-actions {
  padding-top:5px;
  padding-bottom:5px;
  padding-left: 30px;
  padding-right: 30px;
  background: #d4d6da;
  /*background: #d80707;*/
  border-radius: 12px;
  display: grid;
  grid-template-columns: 20% 80%;   /* ⭐ fixed ratio */
  column-gap: 24px;
  row-gap: 8px;
  align-items: center;
}

.actions-header {
  grid-column: 1 / 3;
  text-align: center;
}

.actions-left {
  display: flex;
  flex-direction: column;
  gap: 6px;
  min-width: 130px;
  flex-shrink: 0;
}

.actions-title {
  font-size: 13px;
  font-weight: 600;
  color: #1a1a2e;
}

.actions-note {
  font-size: 12px;
  color: #6b7280;
  line-height: 1.4;
}

.actions-right {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  padding: 0;
  background: transparent;
  border-radius: 0;
  box-shadow: none;
}

/* ══ COPY BUTTON ══ */
.click-here-btn {
  background: #1a3a6b;
  color: #fff;
  border: none;
  padding: 9px 18px;
  font-size: 13px;
  font-weight: 600;
  border-radius: 8px;
  cursor: pointer;
  transition: background 0.18s ease, transform 0.1s ease;
  white-space: nowrap;
}

.click-here-btn:hover {
  background: #142d55;
  transform: translateY(-1px);
}

.click-here-btn:active {
  transform: translateY(0);
}

/* ══ AI PILLS ══ */
.ai-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 7px 13px;
  background: #fff;
  border: 1.5px solid #e5e7eb;
  border-radius: 999px;
  font-size: 13px;
  font-weight: 500;
  color: #374151;
  text-decoration: none;
  transition: all 0.18s ease;
  white-space: nowrap;
}

.ai-pill:hover {
  border-color: #1a3a6b;
  color: #1a3a6b;
  background: #eef1f9;
  transform: translateY(-1px);
}

/* Color dots inside pills — add a span.ai-dot inside each pill */
.ai-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  display: inline-block;
  flex-shrink: 0;
}

.ai-dot--chatgpt    { background: #10a37f; }
.ai-dot--perplexity { background: #6366f1; }
.ai-dot--gemini     { background: #e8a325; }
.ai-dot--grok       { background: #e03d3d; }
.ai-dot--metaai     { background: #0866ff; }
.ai-dot--copilot    { background: #0078d4; }

/* ══ DESC SECTION ══ */
.desc-section {
  margin-top: 12px;
}
}

/* ══ RESPONSIVE ══ */
@media (max-width: 768px) {
  .main-container {
    padding: 12px;
  }

  .question-block {
    padding: 18px 16px;
  }

  .question-actions {
    flex-direction: column;
    gap: 14px;
  }

  .actions-left {
    min-width: unset;
    width: 100%;
  }

  .click-here-btn {
    width: 100%;
    text-align: center;
  }

  .actions-note {
    text-align: center;
  }

  .actions-right {
    width: 100%;
  }
}
